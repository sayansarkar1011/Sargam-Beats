<?xml version="1.0" encoding="utf-8"?>

<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="22dp"
    android:background="?attr/colorSurface">


    <!-- TITLE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎧 Equalizer"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"/>



    <!-- BASS CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="25dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Bass"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>


                <TextView
                    android:id="@+id/tvBassPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#F44336"
                    android:textStyle="bold"/>

            </LinearLayout>


            <SeekBar
                android:id="@+id/seekBass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progressTint="#F44336"
                android:thumbTint="#F44336"/>


        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>



    <!-- TREBLE CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Treble"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>


                <TextView
                    android:id="@+id/tvTreblePercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#F44336"
                    android:textStyle="bold"/>

            </LinearLayout>


            <SeekBar
                android:id="@+id/seekTreble"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1000"
                android:progressTint="#F44336"
                android:thumbTint="#F44336"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>



    <!-- VOLUME CARD -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="3dp"
        app:cardBackgroundColor="?attr/colorSurfaceVariant">


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="15dp">


            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">


                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Volume Boost"
                    android:textStyle="bold"
                    android:textColor="?attr/colorOnSurface"/>


                <TextView
                    android:id="@+id/tvVolumePercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="#F44336"
                    android:textStyle="bold"/>

            </LinearLayout>


            <SeekBar
                android:id="@+id/seekVolumeBoost"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="2000"
                android:progressTint="#F44336"
                android:thumbTint="#F44336"/>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>



    <!-- FREQUENCY -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Frequency"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginTop="22dp"/>


    <LinearLayout
        android:id="@+id/equalizerBandsContainer"
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:layout_marginTop="10dp"
        android:gravity="center"
        android:orientation="horizontal"/>


</LinearLayout>