<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:paddingHorizontal="12dp"
    android:paddingVertical="8dp">


    <!-- Playlist Icon -->
    <ImageView
        android:id="@+id/ivPlaylistIcon"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:scaleType="centerCrop"
        android:src="@drawable/playlist"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>


    <!-- Playlist Animation -->
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottiePlaylist"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:visibility="gone"
        app:lottie_rawRes="@raw/playing"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:layout_constraintStart_toStartOf="@id/ivPlaylistIcon"
        app:layout_constraintEnd_toEndOf="@id/ivPlaylistIcon"
        app:layout_constraintTop_toTopOf="@id/ivPlaylistIcon"
        app:layout_constraintBottom_toBottomOf="@id/ivPlaylistIcon"/>


    <!-- Playlist Name -->
    <TextView
        android:id="@+id/tvPlaylistName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Playlist Name"
        android:textSize="15sp"
        android:textStyle="bold"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="12dp"
        app:layout_constraintStart_toEndOf="@id/ivPlaylistIcon"
        app:layout_constraintEnd_toStartOf="@id/tvPlaylistOptions"
        app:layout_constraintTop_toTopOf="@id/ivPlaylistIcon"/>


    <!-- Song Count -->
    <TextView
        android:id="@+id/tvPlaylistSongCount"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="0 Songs"
        android:textSize="13sp"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintStart_toStartOf="@id/tvPlaylistName"
        app:layout_constraintEnd_toEndOf="@id/tvPlaylistName"
        app:layout_constraintTop_toBottomOf="@id/tvPlaylistName"/>


    <!-- Options -->
    <TextView
        android:id="@+id/tvPlaylistOptions"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:text="⋮"
        android:textSize="22sp"
        android:gravity="center"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/ivPlaylistIcon"
        app:layout_constraintBottom_toBottomOf="@id/ivPlaylistIcon"/>


</androidx.constraintlayout.widget.ConstraintLayout>