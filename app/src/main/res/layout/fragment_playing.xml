<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="20dp"
    android:paddingBottom="24dp">

    <ImageView
        android:id="@+id/playerIvFavourite"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:padding="10dp"
        android:src="@drawable/favourite_btn"
        android:contentDescription="Favourite"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <androidx.cardview.widget.CardView
        android:id="@+id/albumArtContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="30dp"
        app:cardCornerRadius="28dp"
        app:cardElevation="12dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintWidth_percent="0.78"
        app:layout_constraintTop_toBottomOf="@id/playerIvFavourite"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/playerIvAlbumArt"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"
            android:contentDescription="Album Art"
            android:src="@drawable/app_logo"/>

    </androidx.cardview.widget.CardView>


    <TextView
        android:id="@+id/playerTvSongTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="30dp"
        android:text="Song"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/albumArtContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/playerTvArtistName"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="Artist"
        android:textSize="15sp"
        android:textColor="?attr/colorOnSurface"
        android:alpha="0.55"
        android:gravity="center"
        android:maxLines="1"
        android:ellipsize="end"
        app:layout_constraintTop_toBottomOf="@id/playerTvSongTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <TextView
        android:id="@+id/playerTvStartTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="12sp"
        android:alpha="0.65"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginTop="28dp"
        app:layout_constraintTop_toBottomOf="@id/playerTvArtistName"
        app:layout_constraintStart_toStartOf="parent"/>


    <TextView
        android:id="@+id/playerTvEndTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="00:00"
        android:textSize="12sp"
        android:alpha="0.65"
        android:textColor="?attr/colorOnSurface"
        app:layout_constraintTop_toTopOf="@id/playerTvStartTime"
        app:layout_constraintEnd_toEndOf="parent"/>


    <SeekBar
        android:id="@+id/playerSeekBar"
        android:layout_width="0dp"
        android:layout_height="35dp"
        android:progressTint="@color/Theme_main"
        android:thumbTint="@color/Theme_main"
        app:layout_constraintTop_toBottomOf="@id/playerTvStartTime"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/playerFabPlayPause"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:contentDescription="Play Pause"
        app:fabCustomSize="70dp"
        app:maxImageSize="45dp"
        app:srcCompat="@drawable/outline_play_arrow_24"
        app:backgroundTint="@color/Theme_main"
        app:tint="@android:color/white"
        app:elevation="10dp"
        app:layout_constraintTop_toBottomOf="@id/playerSeekBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>


    <ImageView
        android:id="@+id/playerIvPrev"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:padding="8dp"
        android:src="@drawable/outline_skip_previous_24"
        android:contentDescription="Previous"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/colorOnSurface"
        android:layout_marginEnd="38dp"
        app:layout_constraintEnd_toStartOf="@id/playerFabPlayPause"
        app:layout_constraintTop_toTopOf="@id/playerFabPlayPause"
        app:layout_constraintBottom_toBottomOf="@id/playerFabPlayPause"/>


    <ImageView
        android:id="@+id/playerIvNext"
        android:layout_width="58dp"
        android:layout_height="58dp"
        android:padding="8dp"
        android:src="@drawable/outline_skip_next_24"
        android:contentDescription="Next"
        android:background="?attr/selectableItemBackgroundBorderless"
        app:tint="?attr/colorOnSurface"
        android:layout_marginStart="38dp"
        app:layout_constraintStart_toEndOf="@id/playerFabPlayPause"
        app:layout_constraintTop_toTopOf="@id/playerFabPlayPause"
        app:layout_constraintBottom_toBottomOf="@id/playerFabPlayPause"/>


    <LinearLayout
        android:id="@+id/playerControlsContainer"
        android:layout_width="0dp"
        android:layout_height="50dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


        <ImageView
            android:id="@+id/playerIvShuffle"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="13dp"
            android:src="@drawable/shuffle_btn"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Shuffle"/>


        <ImageView
            android:id="@+id/playerIvRepeat"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="13dp"
            android:src="@drawable/repeat"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Repeat"/>


        <ImageView
            android:id="@+id/playerIvEqualizer"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="13dp"
            android:src="@drawable/equilizer"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Equalizer"/>


        <ImageView
            android:id="@+id/playerIvShare"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:padding="13dp"
            android:src="@drawable/share"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Share"/>


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>