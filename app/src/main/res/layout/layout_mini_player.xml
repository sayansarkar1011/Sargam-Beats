<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/miniPlayerRoot"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="?attr/colorSurface"
    android:elevation="8dp"
    android:visibility="visible">

    <!-- 🔥 SEEK BAR (TRUE EDGE TO EDGE, NO GAP) -->
    <SeekBar
        android:id="@+id/miniSeekBar"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:minHeight="0dp"
        android:maxHeight="4dp"
        android:padding="0dp"
        android:paddingStart="0dp"
        android:paddingEnd="0dp"
        android:paddingLeft="0dp"
        android:paddingRight="0dp"
        android:splitTrack="false"
        android:thumbOffset="0dp"
        android:thumb="@drawable/seekbar_thumb"
        android:progressDrawable="@drawable/seekbar_mini_progress"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- CONTENT -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/miniContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/miniSeekBar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ALBUM ART -->
        <ImageView
            android:id="@+id/miniIvAlbum"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:src="@drawable/app_logo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>

        <!-- TEXT -->
        <LinearLayout
            android:id="@+id/miniTextContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            app:layout_constraintStart_toEndOf="@id/miniIvAlbum"
            app:layout_constraintEnd_toStartOf="@id/miniControls"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <TextView
                android:id="@+id/miniTvTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Song"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?attr/colorOnSurface"
                android:singleLine="true"
                android:ellipsize="end"/>

            <TextView
                android:id="@+id/miniTvArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Artist"
                android:textSize="12sp"
                android:textColor="?attr/colorOnSurfaceVariant"
                android:singleLine="true"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- CONTROLS -->
        <LinearLayout
            android:id="@+id/miniControls"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <ImageView
                android:id="@+id/miniBtnPrev"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:src="@drawable/outline_skip_previous_24"
                android:paddingLeft="5dp"
                app:tint="?attr/colorOnSurface"/>

            <ImageView
                android:id="@+id/miniBtnPlayPause"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:layout_marginHorizontal="6dp"
                android:src="@drawable/outline_play_arrow_24"
                android:paddingLeft="5dp"
                app:tint="?attr/colorOnSurface"/>

            <ImageView
                android:id="@+id/miniBtnNext"
                android:layout_width="50dp"
                android:layout_height="40dp"
                android:src="@drawable/outline_skip_next_24"
                android:paddingLeft="5dp"
                app:tint="?attr/colorOnSurface"/>
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
